#: includes/help.php:63
msgid "Tips for Best Results"
msgstr ""

#: includes/help.php:65
msgid "Share Image Size"
msgstr ""

#: includes/help.php:66
msgid "For optimal display on social media platforms, use a share image that is at least 1200x630 pixels. This is the standard Open Graph image size recommended by Facebook and most other platforms."
msgstr ""

#: includes/help.php:71
msgid "Share Text Length"
msgstr ""

#: includes/help.php:72
msgid "Keep your share text between 50 and 160 characters. Most social media platforms truncate longer descriptions."
msgstr ""

#: includes/help.php:77
msgid "Favicon Image"
msgstr ""

#: includes/help.php:78
msgid "For the favicon, upload a square PNG image. The plugin automatically generates a properly sized 32x32 pixel version for browser tab display."
msgstr ""

#: includes/help.php:83
msgid "Cache"
msgstr ""

#: includes/help.php:84
msgid "Social media platforms cache shared URLs. If you update your sharing settings, use the sharing debugger tools from Facebook and Twitter/X to refresh the cached preview for your URL."
msgstr ""

